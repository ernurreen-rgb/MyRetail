MYRETAIL_ENVIRONMENT=development
MYRETAIL_LOG_LEVEL=INFO
MYRETAIL_TENANT_SLUG=myretail
MYRETAIL_AUTH_SECRET=
MYRETAIL_AUTH_TOKEN_TTL_SECONDS=3600
MYRETAIL_AUTH_RATE_LIMIT_ATTEMPTS=5
MYRETAIL_AUTH_RATE_LIMIT_CLIENT_ATTEMPTS=50
MYRETAIL_AUTH_RATE_LIMIT_WINDOW_SECONDS=300
MYRETAIL_AUTH_RATE_LIMIT_CAPACITY=10000
MYRETAIL_ERPNEXT_BASE_URL=http://myretail.localhost:8080
MYRETAIL_ERPNEXT_API_KEY=
MYRETAIL_ERPNEXT_API_SECRET=
MYRETAIL_ERPNEXT_TIMEOUT_SECONDS=10
MYRETAIL_ERPNEXT_SELLING_PRICE_LIST=Standard Selling
MYRETAIL_ERPNEXT_BUYING_PRICE_LIST=Standard Buying
MYRETAIL_ERPNEXT_COMPANY=MyRetail Demo
MYRETAIL_ERPNEXT_API_USER=myretail-api@local.test
# JSON object keyed by cashier email; empty means POS access is denied.
MYRETAIL_POS_CASHIER_ASSIGNMENTS={}
MYRETAIL_DEFAULT_CURRENCY=KZT
MYRETAIL_STOCK_IDEMPOTENCY_DB_PATH=tmp/stock_idempotency.sqlite3
MYRETAIL_POS_DB_PATH=tmp/pos.sqlite3
MYRETAIL_STATE_BACKEND=sqlite
MYRETAIL_STATE_DATABASE_URL=
MYRETAIL_STATE_POOL_MIN_SIZE=2
MYRETAIL_STATE_POOL_MAX_SIZE=10
MYRETAIL_STATE_POOL_ACQUIRE_TIMEOUT_SECONDS=5
MYRETAIL_STATE_STATEMENT_TIMEOUT_MS=5000
MYRETAIL_STATE_LOCK_TIMEOUT_MS=2000
MYRETAIL_STATE_POSTGRES_SSL_MODE=require
# MYRETAIL_STATE_POSTGRES_SSL_ROOT_CERT_PATH=/path/to/ca.pem
